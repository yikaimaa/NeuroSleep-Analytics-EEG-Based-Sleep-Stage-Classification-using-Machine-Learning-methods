library(dplyr)
library(knitr)
library(tibble)
results_tbl <- tribble(
~Section, ~Model, ~Setting, ~Accuracy, ~Macro_F1, ~N1_Recall, ~Note,
"6.1", "XGBoost", "Subject-level split", 0.9112, 0.6785, "0.160",
"Strong baseline; weakest on N1",
"6.2", "Attention", "Fixed-split", 0.8714, 0.7174, "0.750",
"Higher N1 recall than U-Sleep-inspired",
"6.2", "U-Sleep-inspired", "Fixed-split", 0.8902, 0.7261, "0.660",
"Best overall fixed-split deep model",
"6.3", "Attention", "Reduced-compute subject-level CV + HMM (w=0.0)", 0.8461, 0.5994, "48/170",
"Baseline reduced-CV setting",
"6.3", "Attention", "Reduced-compute subject-level CV + HMM (w=0.5)", 0.8600, 0.6069, "27/170",
"Best macro F1 under CV",
"6.3", "Attention", "Reduced-compute subject-level CV + HMM (w=1.0)", 0.8646, 0.6064, "26/170",
"Best accuracy under CV",
"6.3", "Attention", "Reduced-compute subject-level CV + HMM (w=2.0)", 0.8541, 0.5828, "22/170",
"Over-smoothed; lower macro F1",
"6.4", "U-Sleep-inspired", "Reduced-compute subject-level CV + HMM (w=0.0)", 0.2836, 0.1606, "0.790",
"Exploratory only; unstable under reduced compute",
"6.4", "U-Sleep-inspired", "Reduced-compute subject-level CV + HMM (w=0.5)", 0.4570, 0.1922, "0.000",
"Exploratory only; N1 collapsed after HMM"
) %>%
mutate(
Accuracy = sprintf("%.4f", Accuracy),
Macro_F1 = sprintf("%.4f", Macro_F1)
)
kable(
results_tbl,
col.names = c("Section", "Model", "Setting", "Accuracy", "Macro F1", "N1 Recall", "Notes"),
align = c("c", "l", "l", "c", "c", "c", "l"),
caption = "Summary of Section 6 results across XGBoost baseline, fixed-split deep models, and reduced-compute subject-level cross-validation with HMM decoding."
)
